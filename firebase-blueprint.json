{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile that tracks credits.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "credits": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "credits", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Contains user configurations and credits."
    }
  }
}
